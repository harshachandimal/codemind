# Environment files — never commit real credentials
.env
.env.*
!.env.example

# PHP / Composer dependencies
vendor/

# Node.js dependencies
node_modules/

# Build output
dist/
build/

# Laravel specific
/backend/storage/*.key
/backend/storage/logs/*.log
/backend/bootstrap/cache/*.php

# IDE and editor directories
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage and test output
coverage/
*.lcov
.nyc_output/

# Optional npm cache
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Vite temporary files
*.local

# Docker override files (keep docker-compose.yml, ignore local overrides)
docker-compose.override.yml

# ─── Tracer service (tracer/) ──────────────────────────────────────────────────
# Scoped rules ensure tracer/src and tracer/package.json remain tracked.
tracer/node_modules/
tracer/dist/
tracer/.env
tracer/.env.*
