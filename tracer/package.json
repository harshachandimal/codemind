{
  "name": "codemind-tracer",
  "version": "0.1.0",
  "description": "CodeMind tracer service — runtime execution trace generation for JavaScript code (foundation scaffold).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env TRACER_EXECUTION_ENABLED=true JAVA_TRACER_ENABLED=true tsx src/server.ts",
    "dev:exec": "cross-env TRACER_EXECUTION_ENABLED=true JAVA_TRACER_ENABLED=true tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "codemind",
    "tracer",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@lezer/python": "^1.1.19",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
