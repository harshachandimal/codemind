# =============================================================================
# CodeMind — Environment Example
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.
# =============================================================================

# Application
APP_NAME=CodeMind
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# CORS / Cross-origin URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=codemind
DB_USERNAME=postgres
DB_PASSWORD=password

# Redis (used for queue processing in Phase 10+)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# AI Provider (configured in Phase 11)
# Supported values: openai, anthropic, gemini (leave blank until Phase 11)
AI_PROVIDER=
AI_API_KEY=
